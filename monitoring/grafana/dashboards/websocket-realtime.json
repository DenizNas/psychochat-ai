            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(rate(psychochat_websocket_heartbeat_timeouts_total[5m]))",
          "legendFormat": "Heartbeat Timeouts",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Heartbeat Timeout Rate",
      "type": "timeseries"
    }
